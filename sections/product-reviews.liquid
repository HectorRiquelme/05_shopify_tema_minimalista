{%- comment -%}
  Seccion de reviews usando metaobjects de Shopify.

  Requiere un metaobject con tipo "review" y los siguientes campos:
    - autor (single_line_text_field)
    - rating (number_integer, 1-5)
    - comentario (multi_line_text_field)
    - fecha (date)
    - producto (product_reference)

  Para asociar reviews a un producto, se crea un metafield en el producto:
    - namespace: custom
    - key: reviews
    - tipo: list.metaobject_reference (tipo: review)
{%- endcomment -%}

{%- assign reviews = product.metafields.custom.reviews.value -%}

<section class="product-reviews" data-section-id="{{ section.id }}">
  <div class="container">
    <div class="product-reviews__header">
      <h2>{{ section.settings.heading }}</h2>
      {%- if reviews != blank -%}
        <span class="product-reviews__count">
          {{ reviews.size }} {{ reviews.size | pluralize: 'opinion', 'opiniones' }}
        </span>
      {%- endif -%}
    </div>

    {%- if reviews != blank and reviews.size > 0 -%}
      <div class="product-reviews__list">
        {%- for review in reviews -%}
          <article class="review-card">
            <div class="review-card__header">
              <div>
                <span class="review-card__author">{{ review.autor.value | default: 'Anonimo' }}</span>
                <div class="review-card__rating">
                  {% render 'star-rating', rating: review.rating.value %}
                </div>
              </div>
              {%- if review.fecha.value != blank -%}
                <time class="review-card__date" datetime="{{ review.fecha.value }}">
                  {{ review.fecha.value | date: '%d/%m/%Y' }}
                </time>
              {%- endif -%}
            </div>
            {%- if review.comentario.value != blank -%}
              <p class="review-card__comment">{{ review.comentario.value }}</p>
            {%- endif -%}
          </article>
        {%- endfor -%}
      </div>
    {%- else -%}
      <p class="text-light">{{ section.settings.empty_message }}</p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Reviews del producto",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Titulo",
      "default": "Opiniones de clientes"
    },
    {
      "type": "text",
      "id": "empty_message",
      "label": "Mensaje sin reviews",
      "default": "Este producto aun no tiene opiniones. Se el primero en opinar."
    }
  ]
}
{% endschema %}
