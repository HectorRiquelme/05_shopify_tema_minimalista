<section class="newsletter section-padding" data-section-id="{{ section.id }}" style="background-color: {{ section.settings.bg_color }};">
  <div class="container">
    <div class="newsletter__inner">
      {%- if section.settings.subtitle != blank -%}
        <p class="section-header__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}

      <h2 class="newsletter__heading">{{ section.settings.heading }}</h2>

      {%- if section.settings.description != blank -%}
        <p class="newsletter__description text-light">{{ section.settings.description }}</p>
      {%- endif -%}

      {%- form 'customer', class: 'newsletter-form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">

        {%- if form.posted_successfully? -%}
          <p class="newsletter__success">{{ section.settings.success_message }}</p>
        {%- endif -%}

        {%- if form.errors -%}
          <p class="newsletter__error">{{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}</p>
        {%- endif -%}

        <div class="newsletter__form-group">
          <input
            type="email"
            name="contact[email]"
            class="form-input newsletter__input"
            placeholder="{{ section.settings.placeholder }}"
            required
            autocomplete="email"
            aria-label="Correo electronico"
          >
          <button type="submit" class="btn btn--primary newsletter__submit">
            {{ section.settings.button_text }}
          </button>
        </div>
      {%- endform -%}
    </div>
  </div>
</section>

<style>
  .newsletter__inner {
    text-align: center;
    max-width: 560px;
    margin: 0 auto;
  }

  .newsletter__heading {
    margin-bottom: 0.5rem;
  }

  .newsletter__description {
    margin-bottom: 2rem;
  }

  .newsletter__form-group {
    display: flex;
    gap: 0;
  }

  .newsletter__input {
    flex: 1;
    border-right: none;
  }

  .newsletter__submit {
    white-space: nowrap;
  }

  .newsletter__success {
    color: #2d7d46;
    margin-bottom: 1rem;
    font-size: 0.9rem;
  }

  .newsletter__error {
    color: #c53030;
    margin-bottom: 1rem;
    font-size: 0.9rem;
  }

  @media (max-width: 480px) {
    .newsletter__form-group {
      flex-direction: column;
      gap: 0.5rem;
    }

    .newsletter__input {
      border-right: 1px solid #ddd;
    }
  }
</style>

{% schema %}
{
  "name": "Newsletter",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitulo",
      "default": "Mantente al dia"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titulo",
      "default": "Suscribete"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Descripcion",
      "default": "Recibe novedades, lanzamientos exclusivos y un 10% de descuento en tu primera compra."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Texto del campo",
      "default": "Tu correo electronico"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Texto del boton",
      "default": "Suscribirse"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Mensaje de exito",
      "default": "Gracias por suscribirte."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Color de fondo",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Newsletter"
    }
  ]
}
{% endschema %}
