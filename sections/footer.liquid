<footer class="site-footer" data-section-id="{{ section.id }}">
  <div class="container">
    <div class="site-footer__grid">
      <div class="site-footer__brand">
        <h3 class="site-footer__heading">{{ settings.brand_name | default: shop.name }}</h3>
        <p class="text-light">{{ settings.brand_description }}</p>
        <div class="site-footer__social">
          {%- if settings.social_instagram != blank -%}
            <a href="{{ settings.social_instagram }}" target="_blank" rel="noopener" aria-label="Instagram">
              {% render 'icon-set', icon: 'instagram' %}
            </a>
          {%- endif -%}
          {%- if settings.social_facebook != blank -%}
            <a href="{{ settings.social_facebook }}" target="_blank" rel="noopener" aria-label="Facebook">
              {% render 'icon-set', icon: 'facebook' %}
            </a>
          {%- endif -%}
          {%- if settings.social_pinterest != blank -%}
            <a href="{{ settings.social_pinterest }}" target="_blank" rel="noopener" aria-label="Pinterest">
              {% render 'icon-set', icon: 'pinterest' %}
            </a>
          {%- endif -%}
          {%- if settings.social_tiktok != blank -%}
            <a href="{{ settings.social_tiktok }}" target="_blank" rel="noopener" aria-label="TikTok">
              {% render 'icon-set', icon: 'tiktok' %}
            </a>
          {%- endif -%}
        </div>
      </div>

      {%- for block in section.blocks -%}
        <div class="site-footer__column" {{ block.shopify_attributes }}>
          <h4 class="site-footer__heading">{{ block.settings.heading }}</h4>
          <div class="site-footer__links">
            {%- for link in block.settings.menu.links -%}
              <a href="{{ link.url }}">{{ link.title }}</a>
            {%- endfor -%}
          </div>
        </div>
      {%- endfor -%}
    </div>

    <div class="site-footer__bottom">
      <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. {{ settings.footer_copyright }}</p>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Pie de pagina",
  "class": "section-footer",
  "max_blocks": 3,
  "settings": [],
  "blocks": [
    {
      "type": "menu",
      "name": "Columna de menu",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Titulo",
          "default": "Enlaces"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "menu",
        "settings": {
          "heading": "Tienda"
        }
      },
      {
        "type": "menu",
        "settings": {
          "heading": "Informacion"
        }
      },
      {
        "type": "menu",
        "settings": {
          "heading": "Ayuda"
        }
      }
    ]
  }
}
{% endschema %}
