{%- style -%}
  .hero-banner--{{ section.id }} {
    min-height: {{ section.settings.height }}vh;
    background-color: {{ section.settings.overlay_color }};
    color: {{ section.settings.text_color }};
  }
  .hero-banner--{{ section.id }} .hero-banner__overlay {
    background-color: {{ section.settings.overlay_color }};
    opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
  }
{%- endstyle -%}

<section class="hero-banner hero-banner--{{ section.id }}" data-section-id="{{ section.id }}">
  {%- if section.settings.image -%}
    <img
      class="hero-banner__image"
      src="{{ section.settings.image | image_url: width: 1920 }}"
      alt="{{ section.settings.image.alt | default: section.settings.heading }}"
      loading="eager"
      width="1920"
      height="{{ 1920 | divided_by: section.settings.image.aspect_ratio | round }}"
    >
  {%- endif -%}

  <div class="hero-banner__overlay" aria-hidden="true"></div>

  <div class="hero-banner__content container">
    {%- if section.settings.subtitle != blank -%}
      <p class="hero-banner__subtitle">{{ section.settings.subtitle }}</p>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h1 class="hero-banner__heading">{{ section.settings.heading }}</h1>
    {%- endif -%}

    {%- if section.settings.description != blank -%}
      <p class="hero-banner__description">{{ section.settings.description }}</p>
    {%- endif -%}

    {%- if section.settings.button_text != blank -%}
      <a href="{{ section.settings.button_link }}" class="btn btn--primary hero-banner__btn">
        {{ section.settings.button_text }}
      </a>
    {%- endif -%}
  </div>
</section>

<style>
  .hero-banner {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero-banner__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-banner__overlay {
    position: absolute;
    inset: 0;
  }

  .hero-banner__content {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 700px;
    padding: 3rem 2rem;
  }

  .hero-banner__subtitle {
    font-size: 0.8rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin-bottom: 1rem;
    opacity: 0.8;
  }

  .hero-banner__heading {
    font-size: clamp(2rem, 5vw, 3.5rem);
    margin-bottom: 1rem;
    color: inherit;
  }

  .hero-banner__description {
    font-size: 1.05rem;
    line-height: 1.7;
    margin-bottom: 2rem;
    opacity: 0.9;
  }

  .hero-banner__btn {
    background-color: #fff;
    color: #1a1a1a;
    border: none;
  }

  .hero-banner__btn:hover {
    background-color: #f0f0f0;
  }
</style>

{% schema %}
{
  "name": "Banner principal",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen de fondo"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitulo",
      "default": "Nueva coleccion"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titulo",
      "default": "Esencia minimalista"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Descripcion",
      "default": "Piezas atemporales disenadas con materiales de la mas alta calidad."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Texto del boton",
      "default": "Explorar"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Enlace del boton"
    },
    {
      "type": "range",
      "id": "height",
      "label": "Altura del banner (vh)",
      "min": 40,
      "max": 100,
      "step": 5,
      "default": 85,
      "unit": "vh"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Color de superposicion",
      "default": "#1a1a1a"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Opacidad de superposicion",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 40,
      "unit": "%"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color del texto",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Banner principal"
    }
  ]
}
{% endschema %}
