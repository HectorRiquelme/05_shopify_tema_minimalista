<section class="testimonials section-padding" data-section-id="{{ section.id }}" style="background-color: {{ section.settings.bg_color }};">
  <div class="container">
    <div class="section-header">
      {%- if section.settings.subtitle != blank -%}
        <p class="section-header__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
      <h2>{{ section.settings.heading }}</h2>
    </div>

    <div class="testimonials__grid grid grid--{{ section.blocks.size | at_most: 3 }}">
      {%- for block in section.blocks -%}
        <div class="testimonial-card" {{ block.shopify_attributes }}>
          <div class="testimonial-card__stars">
            {% render 'star-rating', rating: block.settings.rating %}
          </div>
          <blockquote class="testimonial-card__quote">
            <p>{{ block.settings.quote }}</p>
          </blockquote>
          <div class="testimonial-card__author">
            <span class="testimonial-card__name">{{ block.settings.author }}</span>
            {%- if block.settings.location != blank -%}
              <span class="testimonial-card__location">{{ block.settings.location }}</span>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .testimonial-card {
    text-align: center;
    padding: 2rem;
  }

  .testimonial-card__stars {
    margin-bottom: 1.2rem;
  }

  .testimonial-card__quote {
    font-style: italic;
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--color-text);
    margin-bottom: 1.5rem;
  }

  .testimonial-card__quote p {
    margin: 0;
  }

  .testimonial-card__name {
    display: block;
    font-weight: 500;
    font-size: 0.9rem;
  }

  .testimonial-card__location {
    display: block;
    font-size: 0.8rem;
    color: var(--color-text-light);
    margin-top: 0.2rem;
  }
</style>

{% schema %}
{
  "name": "Testimonios",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitulo",
      "default": "Lo que dicen"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titulo",
      "default": "Nuestros clientes"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Color de fondo",
      "default": "#f5f5f0"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonio",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Cita",
          "default": "La calidad de los materiales y la atencion al detalle superaron mis expectativas."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Autor",
          "default": "Maria Garcia"
        },
        {
          "type": "text",
          "id": "location",
          "label": "Ubicacion",
          "default": "Santiago, Chile"
        },
        {
          "type": "range",
          "id": "rating",
          "label": "Valoracion",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Testimonios",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "quote": "Diseno impecable y materiales de primera calidad. Cada pieza es una obra de arte.",
            "author": "Maria Garcia",
            "location": "Santiago, Chile",
            "rating": 5
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "quote": "Encontre exactamente lo que buscaba. El minimalismo en su maxima expresion.",
            "author": "Carlos Lopez",
            "location": "Buenos Aires, Argentina",
            "rating": 5
          }
        },
        {
          "type": "testimonial",
          "settings": {
            "quote": "El envio fue rapido y el empaque tan cuidado como los productos. Volvere a comprar.",
            "author": "Ana Martinez",
            "location": "Ciudad de Mexico",
            "rating": 5
          }
        }
      ]
    }
  ]
}
{% endschema %}
